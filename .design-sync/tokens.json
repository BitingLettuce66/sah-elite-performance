{
  "$schema": "https://design-tokens.org",
  "meta": {
    "name": "SAH Elite Performance",
    "theme": "Quiet Luxury — dark only",
    "colorScheme": "dark",
    "source": "src/styles.css (:root)"
  },
  "color": {
    "bg":         { "value": "#0B0B0C", "cssVar": "--bg",         "use": "Page background (jet black)" },
    "surface":    { "value": "#141417", "cssVar": "--surface",    "use": "Card / panel surface" },
    "surface2":   { "value": "#1C1C20", "cssVar": "--surface2",   "use": "Inset surface — callouts, inputs, chips" },
    "line":       { "value": "#26262B", "cssVar": "--line",       "use": "Borders, dividers" },
    "text":       { "value": "#ECEAE3", "cssVar": "--text",       "use": "Primary text (warm off-white)" },
    "muted":      { "value": "#8A8A90", "cssVar": "--muted",      "use": "Secondary text, labels, icons" },
    "accent":     { "value": "#7FB2D9", "cssVar": "--accent",     "use": "Primary accent — cool light blue (active, primary buttons, sprint, links)" },
    "accentDim":  { "value": "#46647A", "cssVar": "--accent-dim", "use": "Dimmed accent — upcoming/secondary" },
    "silver":     { "value": "#C9CBD1", "cssVar": "--silver",     "use": "Silver — gym highlight, race" },
    "green":      { "value": "#5DAE7E", "cssVar": "--green",      "use": "Success / done" },
    "red":        { "value": "#C0563E", "cssVar": "--red",        "use": "Destructive" }
  },
  "radius": {
    "card":  { "value": "16px", "cssVar": "--radius",    "use": "Cards, panels" },
    "sm":    { "value": "11px", "cssVar": "--radius-sm", "use": "Buttons, insets" },
    "input": { "value": "10px", "use": "Inputs, small controls" },
    "pill":  { "value": "20px", "use": "Pills / badges" },
    "sheet": { "value": "22px", "use": "Bottom-sheet top corners" }
  },
  "font": {
    "family": { "value": "-apple-system, BlinkMacSystemFont, \"SF Pro Display\", \"Segoe UI\", Roboto, sans-serif" },
    "weights": { "value": [500, 600, 700] }
  },
  "fontSize": {
    "hero":       { "value": "34px", "weight": 700, "use": "Big metric (.stat b)" },
    "cardTitle":  { "value": "25px", "weight": 700, "use": "Card title" },
    "sheetTitle": { "value": "19px", "use": "Bottom-sheet title" },
    "section":    { "value": "17px", "weight": 700, "use": "Section heading" },
    "body":       { "value": "14-15px", "use": "Body text, inputs" },
    "meta":       { "value": "12-13px", "use": "Meta / secondary" },
    "eyebrow":    { "value": "11-12px", "transform": "uppercase", "letterSpacing": "0.06em-0.18em", "use": "Section labels, eyebrows" }
  },
  "layout": {
    "appMaxWidth": { "value": "520px", "use": "Centered mobile frame (#app)" },
    "screenPadding": { "value": "16-18px" }
  }
}
